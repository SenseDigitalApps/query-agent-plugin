{
  "name": "@itsquery/openclaw-query-channel",
  "version": "0.1.0",
  "description": "OpenClaw channel plugin for Query web and mobile messaging",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build && npm test"
  },
  "dependencies": {
    "node-edge-tts": "^1.2.10",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "openclaw": "2026.7.1-2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.7.1-2"
  },
  "engines": {
    "node": ">=22.22.3 <23 || >=24.15.0 <25 || >=25.9.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "compat": {
      "pluginApi": ">=2026.7.1-2",
      "minGatewayVersion": "2026.7.1-2"
    },
    "build": {
      "openclawVersion": "2026.7.1-2",
      "pluginSdkVersion": "2026.7.1-2"
    },
    "channel": {
      "id": "query",
      "label": "Query",
      "blurb": "Connect OpenClaw to Query web and Flutter messaging."
    }
  }
}
