{
  "id": "query",
  "name": "Query",
  "description": "Connects OpenClaw to Query web and Flutter messaging over a persistent WebSocket.",
  "channels": ["query"],
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "channelConfigs": {
    "query": {
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "url": {
            "type": "string",
            "description": "Full ws:// or wss:// URL generated by Query for this bot."
          },
          "token": {
            "type": "string",
            "description": "Query bot token. QUERY_OPENCLAW_TOKEN is used when omitted."
          },
          "heartbeatMs": {
            "type": "integer",
            "minimum": 5000,
            "maximum": 55000,
            "default": 25000
          },
          "origin": {
            "type": "string",
            "description": "Optional WebSocket Origin header required by some Query deployments."
          },
          "reconnectMinMs": {
            "type": "integer",
            "minimum": 100,
            "maximum": 60000,
            "default": 500
          },
          "reconnectMaxMs": {
            "type": "integer",
            "minimum": 1000,
            "maximum": 300000,
            "default": 15000
          },
          "responseTimeoutMs": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3600000,
            "default": 0
          },
          "stateFile": {
            "type": "string",
            "description": "Optional absolute path for the durable response cache."
          },
          "accounts": {
            "type": "object",
            "description": "Multiple Query bot connections keyed by local account id. Use bindings to route each account to its OpenClaw agent.",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "required": ["url"],
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "url": {
                  "type": "string",
                  "description": "Full ws:// or wss:// URL generated by Query for this bot."
                },
                "token": {
                  "type": "string",
                  "description": "Query bot token. QUERY_OPENCLAW_TOKEN is used when omitted."
                },
                "heartbeatMs": {
                  "type": "integer",
                  "minimum": 5000,
                  "maximum": 55000,
                  "default": 25000
                },
                "origin": {
                  "type": "string",
                  "description": "Optional WebSocket Origin header required by some Query deployments."
                },
                "reconnectMinMs": {
                  "type": "integer",
                  "minimum": 100,
                  "maximum": 60000,
                  "default": 500
                },
                "reconnectMaxMs": {
                  "type": "integer",
                  "minimum": 1000,
                  "maximum": 300000,
                  "default": 15000
                },
                "responseTimeoutMs": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 3600000,
                  "default": 0
                },
                "stateFile": {
                  "type": "string",
                  "description": "Optional absolute path for the durable response cache."
                }
              }
            }
          }
        }
      },
      "uiHints": {
        "url": {
          "label": "Query WebSocket URL",
          "placeholder": "wss://api.example.com/ws/openclaw-agent/<bot-id>/"
        },
        "token": {
          "label": "Bot token",
          "sensitive": true
        },
        "heartbeatMs": {
          "label": "Heartbeat interval (ms)",
          "advanced": true
        },
        "origin": {
          "label": "WebSocket Origin",
          "advanced": true
        },
        "reconnectMinMs": {
          "label": "Minimum reconnect delay (ms)",
          "advanced": true
        },
        "reconnectMaxMs": {
          "label": "Maximum reconnect delay (ms)",
          "advanced": true
        },
        "responseTimeoutMs": {
          "label": "Agent response timeout (ms; 0 disables)",
          "advanced": true
        },
        "stateFile": {
          "label": "Response cache path",
          "advanced": true
        }
      }
    }
  }
}
